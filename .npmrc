# Monorepo configuration
auto-install-peers=true
strict-peer-dependencies=false

# Hoisting settings - critical for monorepos
hoist=true
hoist-pattern[]=*eslint*
hoist-pattern[]=*prettier*
hoist-pattern[]=*typescript*

# Symlink node_modules for better compatibility
symlink=true

# Faster installs
side-effects-cache=true
side-effects-cache-readonly=false

# Enable lockfile verification
lockfile=true

# React Native compatibility (for future apps)
node-linker=hoisted




