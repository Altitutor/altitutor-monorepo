{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "lint": {},
    "lint:fix": {},
    "test": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "typecheck": { "dependsOn": ["^build"] }
  }
}

